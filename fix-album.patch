diff --git a/app/src/main/java/com/grindrplus/utils/SuspendResultUtils.kt b/app/src/main/java/com/grindrplus/utils/SuspendResultUtils.kt
--- a/app/src/main/java/com/grindrplus/utils/SuspendResultUtils.kt	(revision 2ec8671538956cfc00e003a2bc747d0b8d603e95)
